# Database (required)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth (required on Heroku — set BETTER_AUTH_URL to your Heroku app URL)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-app.herokuapp.com

# Email (optional)
RESEND_API_KEY=

# Anything platform integrations (optional)
NEXT_PUBLIC_CREATE_BASE_URL=
NEXT_PUBLIC_CREATE_HOST=
NEXT_PUBLIC_PROJECT_GROUP_ID=
ANYTHING_PROJECT_TOKEN=
