# Database (required — also used by `npm run db:generate` and `npm run db:push`)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth (required on Heroku — set BETTER_AUTH_URL to your Heroku app URL)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-app.herokuapp.com

# Public routing
NEXT_PUBLIC_ROOT_DOMAIN=ft9ja.com
NEXT_PUBLIC_APP_URL=https://ft9ja.com

# Super admin (required for /admin)
SUPER_ADMIN_PASSWORD=


# AWS S3 uploads (required for receipts/documents)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=
