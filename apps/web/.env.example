# Database (required — also used by `npm run db:generate` and `npm run db:push`)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Trading telemetry (read-only balance/equity history)
MONGODB_URL=mongodb+srv://user:password@host/?retryWrites=true&w=majority

# Cache — telemetry metrics are cached for 5 minutes (optional; skipped if unset)
REDIS_URL=redis://default:password@host:6379

# Auth (required on Heroku — set BETTER_AUTH_URL to your Heroku app URL)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-app.herokuapp.com

# Public routing
NEXT_PUBLIC_ROOT_DOMAIN=ft9ja.com
NEXT_PUBLIC_APP_URL=https://ft9ja.com

# Super admin (required for /admin)
SUPER_ADMIN_PASSWORD=

# Email (required for outbound app email via SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=FT9ja <accounts@ft9ja.com>
SENDGRID_FT9JA_PARTNER_FROM_EMAIL=FT9ja Partners <accounts@ft9ja.com>
SENDGRID_REPLY_TO_EMAIL=accounts@ft9ja.com

# AWS S3 uploads (required for receipts/documents)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=

# OpenAI (required for partner AI logo generation)
OPENAI_API_KEY=
